<div class="container mt-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center pb-4">
                    <div class="mb-3 mt-2">
                        <i class="fas fa-user-circle text-success" style="font-size: 5rem;"></i>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Account Details</h4>
                    
                    <hr>
                    
                    <div class="text-start px-3">
                        <p class="mb-2"><strong>Username:</strong> <span class="float-end text-muted">{{userProfile.username}}</span></p>
                        <p class="mb-2"><strong>Email:</strong> <span class="float-end text-muted">{{userProfile.email}}</span></p>
                        <p class="mb-2"><strong>ID Number:</strong> <span class="float-end fw-semibold">{{userProfile.id_number}}</span></p>
                        <p class="mb-2"><strong>Status:</strong> 
                            <span class="float-end badge bg-success">{{userProfile.account_status}}</span>
                        </p>
                        <p class="mb-0"><strong>Member Since:</strong> <span class="float-end">{{userProfile.join_date}}</span></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-history text-success me-2"></i>My Purchase History</h5>
                </div>
                <div class="card-body p-0">
                    {{#if transactions.length}}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Date</th>
                                        <th>Item</th>
                                        <th>Qty</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each transactions}}
                                    <tr>
                                        <td class="ps-4 text-muted">{{this.order_date}}</td>
                                        <td class="fw-semibold">{{this.product_name}}</td>
                                        <td>{{this.quantity}}</td>
                                        <td class="fw-bold text-success">₱{{this.total_purchase_price}}</td>
                                        <td>
                                            <span class="badge 
                                                {{#if (eq this.status 'Completed')}}bg-success
                                                {{else if (eq this.status 'Pending')}}bg-warning text-dark
                                                {{else if (eq this.status 'Cancelled')}}bg-danger
                                                {{else}}bg-primary{{/if}}">
                                                {{this.status}}
                                            </span>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    {{else}}
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-box-open fs-1 mb-3 text-light"></i>
                            <h5>No transactions yet</h5>
                            <p>When you buy an item, your receipt will show up here!</p>
                            <a href="/" class="btn btn-outline-success mt-2">Start Shopping</a>
                        </div>
                    {{/if}}
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-store text-primary me-2"></i>My Listings & Sales</h5>
                </div>
                <div class="card-body p-0">
                    {{#if sales.length}}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Date</th>
                                        <th>Item</th>
                                        <th>Qty Sold</th>
                                        <th>Price/Earnings</th>
                                        <th>Buyer Username</th>
                                        <th>Status</th>
                                        <th>Action</th> </tr>
                                </thead>
                                <tbody>
                                    {{#each sales}}
                                    <tr>
                                        <td class="ps-4 text-muted">{{this.display_date}}</td>
                                        <td class="fw-semibold">{{this.product_name}}</td>
                                        <td>{{this.quantity}}</td>
                                        <td class="fw-bold text-success">₱{{this.display_price}}</td>
                                        <td>
                                            <span class="badge {{#if (eq this.buyer_username 'N/A')}}bg-light text-muted border{{else}}bg-secondary{{/if}}">
                                                {{this.buyer_username}}
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge 
                                                {{#if (eq this.status 'Completed')}}bg-success
                                                {{else if (eq this.status 'Pending')}}bg-warning text-dark
                                                {{else if (eq this.status 'Available')}}bg-info text-dark
                                                {{else if (eq this.status 'Cancelled')}}bg-danger
                                                {{else}}bg-primary{{/if}}">
                                                {{this.status}}
                                            </span>
                                        </td>
                                        <td>
                                            {{#if (eq this.status 'Available')}}
                                                <form action="/user/delete-listing" method="POST" class="m-0" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                                    <input type="hidden" name="productId" value="{{this.product_id}}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Listing">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {{else}}
                                                <button class="btn btn-sm btn-outline-secondary border-0" disabled title="Cannot delete items that have been ordered">
                                                    <i class="fas fa-lock"></i>
                                                </button>
                                            {{/if}}
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    {{else}}
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-store-slash fs-1 mb-3 text-light"></i>
                            <h5>No items listed yet</h5>
                            <p>When you post an item for sale, you can track its status here!</p>
                            <a href="/user/sell" class="btn btn-outline-primary mt-2">Post an Item</a>
                        </div>
                    {{/if}}
                </div>
            </div>

        </div>
    </div>
</div>