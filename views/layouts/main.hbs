<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
        {{#if stylesheets}}
            {{#each stylesheets}}
                <link rel="stylesheet" href="/styles/{{this}}">
            {{/each}}
        {{/if}}
    </head>
    <body class="bg-light">
        
        <header class="top-bar bg-white py-3 border-bottom mb-4 shadow-sm">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="logo">
                    <a href="/" class="text-success text-decoration-none fs-4 fw-bold">🏹 Animarket</a>
                </div>

                <div class="user-actions d-flex align-items-center gap-3">
                    {{#if user}}
                        <a href="/user/cart" class="btn btn-outline-success fw-bold shadow-sm">
                            <i class="fas fa-shopping-cart"></i> Cart
                        </a>
                        <a href="/user/sell" class="btn btn-success fw-bold shadow-sm">+ Post Item</a>
                        <span class="text-muted fw-semibold">Hi, {{user.username}}</span>
                        <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
                    {{else}}
                        <a href="/login" class="text-decoration-none text-dark fw-semibold">Login</a>
                        <a href="/register" class="btn btn-primary shadow-sm">Sign Up</a>
                    {{/if}}
                </div>
            </div>
        </header>

        <main class="container">
            {{{body}}}
        </main>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
