                        <button class="btn-wishlist">Add</button>
                    </div>
                </div>
            </article>

            <article class="product-card">
                <div class="product-image">
                    <div class="img-placeholder">Image</div>
                </div>
                <div class="product-info">
                    <h4 class="product-title">Pre-loved Accounting Book</h4>
                    <div class="product-price">
                        <span class="currency">₱</span>
                        <span class="price-amount">450.00</span>
                    </div>
                    <div class="product-footer">
                        <span class="stock">Stock: 1</span>
                        <button class="btn-wishlist"> Add</button>
                    </div>
                </div>
            </article>

        </div>
