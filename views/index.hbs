<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to Animarket</title>
    <link rel="stylesheet" href="/style.css"> </head>
<body>

    <header class="top-bar">
        <div class="nav-container">
            <div class="logo">🏹 Animarket</div>
            <div class="search-container">
                <input type="text" placeholder="Search for products, sellers, or DLSU merch...">
                <button type="button" class="btn-search">Search</button>
            </div>
            <div class="user-actions">
                <a href="/login" class="nav-link">Login</a>
                <a href="/register" class="nav-link">Sign Up</a>
                <a href="/wishlist" class="nav-link"> Wishlist</a>
            </div>
        </div>
    </header>

    <main class="main-content">
        <section class="hero-banner">
            <div class="banner-content">
                <h2>Welcome to Animarket</h2>
                <p>The exclusive marketplace for DLSU Taft students and faculty.</p>
            </div>
        </section>

        <section class="product-feed">
            <div class="section-header">
                <h3>Daily Discoveries</h3>
            </div>
            
            <div class="product-grid">
                
                <article class="product-card">
                    <div class="product-image">
                        <div class="img-placeholder">Image</div>
                    </div>
                    <div class="product-info">
                        <h4 class="product-title">DLSU Lanyard 2026</h4>
                        <div class="product-price">
                            <span class="currency">₱</span>
                            <span class="price-amount">150.00</span>
                        </div>
                        <div class="product-footer">
                            <span class="stock">Stock: 25</span> <button class="btn-wishlist">Add</button>
                        </div>
                    </div>
                </article>

                <article class="product-card">
                    <div class="product-image">
                        <div class="img-placeholder">Image</div>
                    </div>
                    <div class="product-info">
                        <h4 class="product-title">Pre-loved Accounting Book</h4>
                        <div class="product-price">
                            <span class="currency">₱</span>
                            <span class="price-amount">450.00</span>
                        </div>
                        <div class="product-footer">
                            <span class="stock">Stock: 1</span>
                            <button class="btn-wishlist"> Add</button>
                        </div>
                    </div>
                </article>

            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="footer-content">
            <p>&copy; 2026 Animarket. DLSU Taft Campus Exclusive.</p>
        </div>
    </footer>

</body>
</html>