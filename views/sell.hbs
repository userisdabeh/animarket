<div class="form-container modern-form">
    <div class="form-header">
        <h2>Sell an Item</h2>
        <p>List your pre-loved items, books, or merch for the Taft community.</p>
    </div>

    <form action="/api/products" method="POST" id="sellForm">
        
        <div class="form-group">
            <label for="productName">Item Name</label>
            <input type="text" id="productName" name="productName" placeholder="e.g. CCS Lanyard 2024" required>
        </div>

        <div class="form-group">
            <label>Product Image</label>
            <div class="file-upload-wrapper" id="dropZone">
                <input type="file" id="imageFile" accept="image/*" required>
                <div class="file-upload-text" id="uploadText">
                    <p>Drag and drop an image, or <span style="color: var(--dlsu-green); font-weight: bold;">browse</span></p>
                </div>
                <img id="imagePreview" class="image-preview" src="" alt="Image Preview">
            </div>
            <input type="hidden" id="imageBase64" name="imageBase64">
        </div>

        <div class="form-row">
            <div class="form-group half-width">
                <label for="category">Category</label>
                <select id="category" name="category" required onchange="enforcePriceCap()">
                    <option value="" disabled selected>Select...</option>
                    <option value="Academic">Academic</option>
                    <option value="Uniforms">Uniforms</option>
                    <option value="Merch">Merch</option>
                    <option value="Tickets">Tickets</option>
                </select>
            </div>

            <div class="form-group half-width">
                <label for="price">Price (₱)</label>
                <input type="number" id="price" name="price" placeholder="0.00" min="0" step="0.01" required>
            </div>
        </div>
        
        <small id="priceWarning" class="price-warning">*UAAP Tickets are strictly capped at ₱500.00.</small>

        <div class="form-group">
            <label for="description">Description & Condition</label>
            <textarea id="description" name="description" rows="4" placeholder="Describe any flaws or meetup preferences..." required></textarea>
        </div>

        <button type="submit" class="btn-submit">Post Listing</button>
    </form>
</div>

<script>
    const imageInput = document.getElementById('imageFile');
    const imagePreview = document.getElementById('imagePreview');
    const uploadText = document.getElementById('uploadText');
    const base64Input = document.getElementById('imageBase64');

    imageInput.addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                base64Input.value = e.target.result;
                imagePreview.src = e.target.result;
                imagePreview.style.display = 'block';
                uploadText.style.display = 'none';
            };
            reader.readAsDataURL(file);
        } else {
            imagePreview.style.display = 'none';
            uploadText.style.display = 'block';
            base64Input.value = '';
        }
    });

    function enforcePriceCap() {
        const category = document.getElementById("category").value;
        const priceInput = document.getElementById("price");
        const warning = document.getElementById("priceWarning");
        
        if (category === "Tickets") {
            priceInput.max = "500";
            warning.style.display = "block";
            if (priceInput.value > 500) priceInput.value = 500;
        } else {
            priceInput.removeAttribute("max");
            warning.style.display = "none";
        }
    }
</script>